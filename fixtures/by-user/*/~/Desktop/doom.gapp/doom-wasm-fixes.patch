diff --git a/src/doom/p_user.c b/src/doom/p_user.c
index 772871e..39a9439 100644
--- a/src/doom/p_user.c
+++ b/src/doom/p_user.c
@@ -27,6 +27,7 @@
 #include "p_local.h"
 
 #include "doomstat.h"
+#include "r_state.h"
 
 
 
@@ -264,7 +265,14 @@ void P_PlayerThink (player_t* player)
     
     P_CalcHeight (player);
 
-    if (player->mo->subsector->sector->special)
+    // Defensive bounds check: mo->subsector has intermittently been observed
+    // holding an invalid pointer here in the WASM build (out-of-bounds
+    // memory trap dereferencing it), root cause not yet confirmed. Skip
+    // rather than crash if it's not a valid subsectors[] entry.
+    if (player->mo->subsector != NULL
+	&& player->mo->subsector >= subsectors
+	&& player->mo->subsector < subsectors + numsubsectors
+	&& player->mo->subsector->sector->special)
 	P_PlayerInSpecialSector (player);
     
     // Check for weapon change.
diff --git a/src/doom/r_things.c b/src/doom/r_things.c
index b9e879c..4410bdd 100644
--- a/src/doom/r_things.c
+++ b/src/doom/r_things.c
@@ -32,6 +32,7 @@
 #include "w_wad.h"
 
 #include "r_local.h"
+#include "r_state.h"
 
 #include "doomstat.h"
 
@@ -742,9 +743,21 @@ void R_DrawPlayerSprites (void)
     pspdef_t*	psp;
     
     // get light level
-    lightnum =
-	(viewplayer->mo->subsector->sector->lightlevel >> LIGHTSEGSHIFT) 
-	+extralight;
+    // Defensive bounds check: same intermittent invalid mo->subsector issue
+    // as p_user.c's P_PlayerThink (root cause not yet confirmed) — fall back
+    // to light level 0 rather than crash if it's not a valid subsectors[] entry.
+    if (viewplayer->mo->subsector != NULL
+	&& viewplayer->mo->subsector >= subsectors
+	&& viewplayer->mo->subsector < subsectors + numsubsectors)
+    {
+	lightnum =
+	    (viewplayer->mo->subsector->sector->lightlevel >> LIGHTSEGSHIFT)
+	    +extralight;
+    }
+    else
+    {
+	lightnum = extralight;
+    }
 
     if (lightnum < 0)		
 	spritelights = scalelight[0];
